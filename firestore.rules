rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers ----
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // ---- collections ----
    match /users/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow create: if isSelf(uid) && request.resource.data.role == 'employee';
      allow update, delete: if isAdmin();
    }

    match /attendance/{punchId} {
      allow read: if isSelf(resource.data.userId) || isAdmin();
      allow create: if isSelf(request.resource.data.userId);
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /dailySummary/{docId} {
      allow read: if resource == null || isSelf(resource.data.userId) || isAdmin();
      allow write: if isSelf(request.resource.data.userId) || isAdmin();
    }

  }
}
